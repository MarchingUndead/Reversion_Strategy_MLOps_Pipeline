# Copy to .env and fill in. Safe to commit.

# --- MLflow ---
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=reversion-grid
MLFLOW_PORT=5000

# --- Model server (src/serve.py) ---
# Forms accepted:
#   auto:<name>                     -> latest Production (or latest version if no Production)
#   models:/<name>/Production       -> mlflow re-resolves on every container start
#   models:/<name>/<version>        -> pin to a specific version
#   runs:/<run_id>/model_classifier -> pin to a specific run's artefact
# `auto:` requires `python scripts/register_best.py --promote` to have run at least once.
MODEL_URI=auto:reversion-classifier-pos0
SERVE_HOST=0.0.0.0
SERVE_PORT=5002

# --- Airflow webserver <-> scheduler internal request signing ---
# Any 32+ char string; both containers must agree on it. Without this each
# container generates its own random key on boot and the UI's task-log fetch
# fails with 403 Forbidden from http://airflow-scheduler:8793/log/...
AIRFLOW_SECRET_KEY=change-me-to-a-random-32char-string

# --- Streamlit ---
STREAMLIT_PORT=8501

# --- Prometheus / Grafana ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
NODE_EXPORTER_PORT=9100
ALERTMANAGER_PORT=9093

# --- Alertmanager email (Gmail SMTP) ---
# Generate an App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification on the Gmail account).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_APP_PASSWORD=
ALERT_TO=

# --- Airflow ---
# Linux/WSL2: set to your host UID so the scheduler writes logs/ as you, not root.
# Windows / Docker Desktop: ignore — leave blank or 50000.
AIRFLOW_UID=50000
# Airflow EmailOperator + email_on_failure both target ALERT_TO (above), so a
# single inbox covers Alertmanager pages and DAG-failure notifications. The
# `smtp_default` connection is provisioned by airflow-init from SMTP_USER /
# SMTP_APP_PASSWORD on first boot.
