# Copy to .env and fill in. Safe to commit.

# --- MLflow ---
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=reversion-skeleton

# --- Model server (src/serve.py) ---
MODEL_URI=
SERVE_HOST=0.0.0.0
SERVE_PORT=5002

# --- Streamlit ---
STREAMLIT_PORT=8501

# --- Prometheus / Grafana ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
NODE_EXPORTER_PORT=9100
ALERTMANAGER_PORT=9093

# --- Alertmanager email (Gmail SMTP) ---
# Generate an App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification on the Gmail account).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_APP_PASSWORD=
ALERT_TO=
